# ===========================================
# Drone Receiving Platform - Environment Config
# ===========================================

# --- TimescaleDB ---
POSTGRES_USER=drone_admin
POSTGRES_PASSWORD=drone_secret
POSTGRES_DB=drone_station
DATABASE_URL=postgresql+asyncpg://drone_admin:drone_secret@timescaledb:5432/drone_station

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_IMAGES=inspection-images
MINIO_BUCKET_LOGS=flight-logs
MINIO_USE_SSL=false

# --- FastAPI ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production

# --- ROS 2 ---
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Anthropic (optional) ---
# 留空則 fallback 到範本報告；設定後 mission 完成時自動產生 AI 巡檢報告
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
